    private bool showAddForm = false;

    // Variables pour les commentaires
    private Dictionary<string, List<Comment>> commentsCache = new();
    private Dictionary<string, bool> expandedComments = new();
    private Dictionary<string, string> newCommentText = new();
    private Dictionary<string, bool> showCommentForm = new();
    
    // Audio state
    private bool isPlaying = false;
    
    // Variables pour l'édition des commentaires
    private int? editingCommentId = null;
    private string editingCommentText = string.Empty;

    // Variables pour la modal de confirmation
    private string confirmationMessage = string.Empty;
    private string pendingActionType = string.Empty; // "delete_restaurant" ou "delete_comment"
    private Restaurant? pendingRestaurant = null;
    private string? pendingCommentRestaurantNom = null;
    private Comment? pendingComment = null;

    // Scroll to edit form after render
    private bool shouldScrollToEditForm = false;
    private bool isLoading = false;
    private string loadingMessage = string.Empty;

    // Tri des restaurants
    private string sortBy = "rating"; // rating, price, created_at
    private bool sortAscending = false; // false = descendant, true = ascendant

    // Gestion du filtrage manuel
    private CancellationTokenSource? searchCancellation = null;

    protected override async Task OnInitializedAsync()
    {
        await RunWithLoading("Chargement des restaurants en cours…", async () =>
        {
            await ChargerRestaurants();
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (shouldScrollToEditForm)
        {
            shouldScrollToEditForm = false;
            await JS.InvokeVoidAsync("scrollIntoViewById", "editRestaurantForm");
        }
    }

    private async Task ChargerRestaurants()
    {
        try
        {
            ListeRestaurants = await SupabaseService.GetRestaurantsAsync();
            RestaurantTypeOptions = ListeRestaurants
                .Select(r => r.RestaurantType)
                .Where(value => !string.IsNullOrWhiteSpace(value))
                .Distinct()
                .OrderBy(value => value)
                .ToList();

            VilleOptions = ListeRestaurants
                .Select(r => r.Ville)
                .Where(value => !string.IsNullOrWhiteSpace(value))
                .Distinct()
                .OrderBy(value => value)
                .ToList();

            // Pré-charger les commentaires pour tous les restaurants
            foreach (var resto in ListeRestaurants)
            {
                var comments = await SupabaseService.GetCommentsByRestaurantAsync(resto.Nom);
                commentsCache[resto.Nom] = comments;
            }

            ApplyFilter();
        }
        catch (Exception ex)
        {
            messageErreur = $"Erreur lors du chargement des restaurants: {ex.Message}";
        }
    }

    private async Task PlayJingle()
    {
        try
        {
            await JS.InvokeVoidAsync("playAudioById", "jingleAudio");
            isPlaying = true;
            messageErreur = string.Empty;
        }
