        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-primary">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Confirmation de la ville détectée</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CancelCityConfirmation" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    <p>Le lien Google Maps fourni a été analysé et une ville a été extraite.</p>
                    <div class="mb-3 p-3" style="background-color: #f8f9fa; border-radius: 0.5rem;">
                        <div><strong>Ville détectée :</strong> @(string.IsNullOrEmpty(extractedAnalysis.Resto.Ville) ? "—" : extractedAnalysis.Resto.Ville)</div>
                        @if (!string.IsNullOrEmpty(extractedAnalysis.SuggestedCity))
                        {
                            <div class="mt-2"><strong>Suggestion :</strong> @extractedAnalysis.SuggestedCity</div>
                        }
                        <div class="mt-2"><strong>Restaurant :</strong> @(string.IsNullOrEmpty(extractedAnalysis.Resto.Nom) ? "—" : extractedAnalysis.Resto.Nom)</div>
                    </div>
                    <p>Tu peux accepter la ville détectée, utiliser la suggestion, ou modifier manuellement si elle n'est pas bonne.</p>
                </div>
                <div class="modal-footer flex-column align-items-stretch gap-2" style="padding: 1rem;">
                    <button type="button" class="btn btn-success w-100" @onclick="AcceptCityAndAdd">Accepter cette ville et enregistrer</button>
                    @if (!string.IsNullOrEmpty(extractedAnalysis.SuggestedCity))
                    {
                        <button type="button" class="btn btn-outline-primary w-100" @onclick="UseSuggestedCityAndAdd">Utiliser la proposition (@extractedAnalysis.SuggestedCity)</button>
                    }
                    <button type="button" class="btn btn-secondary w-100" @onclick="CancelCityConfirmation">Modifier la ville manuellement</button>
                </div>
            </div>
        </div>
    </div>
