    private bool AnyFilterApplied()
    {
        if (!string.IsNullOrWhiteSpace(searchText)) return true;
        // SelectedTypes default contains both Physique and EnLigne
        if (SelectedTypes.Count != 2) return true;
        if (SelectedRestaurantTypes.Count > 0) return true;
        if (SelectedVilles.Count > 0) return true;
        if (SelectedRatings.Count > 0) return true;
        if (SelectedPrices.Count > 0) return true;
        // Default: FilterShowFiable=true and FilterShowNonFiable=false
        if (!FilterShowFiable || FilterShowNonFiable) return true;
        return false;
    }

