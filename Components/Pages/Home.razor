    private string GetSaudiTime(DateTime createdAt)
    {
        var utcTime = DateTime.SpecifyKind(createdAt, DateTimeKind.Utc);
        var saudiTime = utcTime.AddHours(3);
        return saudiTime.ToString("dd/MM/yyyy HH:mm") + " UTC+3";
    }

    private string RenderStars(int rating)
    {
        rating = Math.Clamp(rating, 1, 5);
        return string.Concat(Enumerable.Range(1, rating).Select(_ => "★"));
    }

    private string RenderPriceLevel(int priceLevel)
    {
        priceLevel = Math.Clamp(priceLevel, 1, 3);
        return string.Concat(Enumerable.Range(1, priceLevel).Select(_ => "$"));
    }
