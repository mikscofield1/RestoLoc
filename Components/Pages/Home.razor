@page "/"
@inject IJSRuntime JS
@inject HttpClient Http
@inject SupabaseService SupabaseService
@using RestoLoc.Services

<PageTitle>RestoLoc Pro</PageTitle>

<!-- Full width header banner using the provided PNG image -->
<img src="images/logo.png" alt="Bannière Mahalal" class="header-banner" @onclick="PlayJingle" role="button" style="cursor: pointer;" tabindex="0" aria-label="Cliquez pour écouter le jingle Mahalal" />

<!-- Audio controls -->
@if (isPlaying)
{
    <div class="container mt-2">
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-danger btn-sm p-2" @onclick="StopJingle" title="Stop le jingle">
                <i class="bi bi-stop-fill"></i>
            </button>
        </div>
    </div>
}

<audio id="jingleAudio" src="audio/mahalal.mp3" preload="none"></audio>

<div class="container mt-4">
    @if (isLoading)
    {
        <div class="restaurant-loading-bar mb-4" role="status" aria-live="polite">
            <span class="restaurant-loading-bar__icon">🍜</span>
            <span class="restaurant-loading-bar__label">@loadingMessage</span>
            <span class="restaurant-loading-bar__track">
                <span class="restaurant-loading-bar__fill"></span>
            </span>
        </div>
    }

    <!-- Section Ajouter/Éditer -->
    @if (restoEnEdition == null)
    {
        <div class="card mb-5 border-primary shadow-sm">
            <div class="card-header p-3 bg-light">
                <button class="btn btn-link btn-sm text-primary text-decoration-none" @onclick="@(() => showAddForm = !showAddForm)" data-bs-toggle="collapse" data-bs-target="#addRestaurantForm">
                    <i class="bi @(showAddForm ? "bi-dash-lg" : "bi-plus-lg")"></i> 
                    <span class="fw-bold">Ajouter un restaurant</span>
                </button>
            </div>
            <div id="addRestaurantForm" class="collapse @(showAddForm ? "show" : "")" style="@(showAddForm ? "" : "")">
                <div class="card-body p-3">
                    <p class="small text-muted mb-3">Seul le nom est obligatoire. Les autres champs sont optionnels.</p>
                    <div class="row g-3">
                <div class="col-md-3">
                    <input type="text" @bind="nouveauResto.Nom" class="form-control form-control-sm" placeholder="Nom du restaurant" />
                </div>
                <div class="col-md-3">
                    <input type="text" @bind="nouveauResto.Telephone" class="form-control form-control-sm" placeholder="Téléphone" />
                </div>
                <div class="col-md-2">
                    <input type="text" @bind="nouveauResto.OriginePoulet" class="form-control form-control-sm" placeholder="Origine Poulet" />
                </div>
                <div class="col-md-2">
                    <input type="text" @bind="nouveauResto.OrigineViande" class="form-control form-control-sm" placeholder="Origine Viande" />
                </div>
                <div class="col-md-2">
                    <select @bind="nouveauResto.Type" class="form-select form-select-sm">
                        <option value="@TypeRestaurant.Physique">Boutique Physique</option>
                        <option value="@TypeRestaurant.EnLigne">Commande En Ligne Only</option>
                    </select>
                </div>
                <div class="col-12"></div>
                <div class="col-md-2">
                    <input type="text" @bind="nouveauResto.RestaurantType" class="form-control form-control-sm" placeholder="Type Restaurant" />
                </div>
                <div class="col-md-2">
                    <input type="text" @bind="nouveauResto.Ville" class="form-control form-control-sm" placeholder="Ville" />
                </div>
                <div class="col-md-2">
                    <input type="text" @bind="nouveauResto.Food" class="form-control form-control-sm" placeholder="Type Nourriture" />
                </div>
                <div class="col-md-2">
                    <select @bind="nouveauResto.Rating" class="form-select form-select-sm">
                        <option value="">Note (étoiles)</option>
                        <option value="1">★ 1</option>
                        <option value="2">★★ 2</option>
                        <option value="3">★★★ 3</option>
                        <option value="4">★★★★ 4</option>
                        <option value="5">★★★★★ 5</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select @bind="nouveauResto.PriceLevel" class="form-select form-select-sm">
                        <option value="">Prix</option>
                        <option value="1">$</option>
                        <option value="2">$$</option>
                        <option value="3">$$$</option>
                    </select>
                </div>
                <div class="col-12"></div>
            </div>
            <div class="row g-3">
                @if (nouveauResto.Type == TypeRestaurant.Physique)
                {
                    <div class="col-md-6">
                        <input type="text" @bind="urlGoogleMaps" class="form-control form-control-sm" placeholder="Lien Google Maps (Optionnel)" />
                    </div>
                    <div class="col-md-4"></div>
                }
                else
                {
                    <div class="col-md-6">
                        <input type="text" @bind="nouveauResto.LienCommande" class="form-control form-control-sm" placeholder="Lien du site de commande (Optionnel)" />
                    </div>
                    <div class="col-md-4"></div>
                }
                <div class="col-md-2 d-flex align-items-center">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="nouveauResto.EstFiable" id="fiableCheck">
                        <label class="form-check-label small" for="fiableCheck">Fiable ✅</label>
                    </div>
                </div>
                <div class="col-12 text-end">
                    <button class="btn btn-success btn-sm px-4" @onclick="AjouterLeRestaurant">Enregistrer</button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(messageErreur)) { <div class="text-danger small mt-2">@messageErreur</div> }
                </div>
            </div>
        </div>
    }
    else
    {
        <div id="editRestaurantForm" class="card p-3 mb-5 border-warning shadow-sm">
            <h5 class="card-title text-warning"><i class="bi bi-pencil-fill"></i> Éditer le restaurant</h5>
            <div class="row g-3 mb-2">
                <div class="col-12 col-md-3">
                    <label class="form-label fw-bold small text-warning">Nom du restaurant</label>
                    <input type="text" @bind="restoEnEdition.Nom" class="form-control form-control-sm" placeholder="Nom du restaurant" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label fw-bold small text-warning">Téléphone</label>
                    <input type="text" @bind="restoEnEdition.Telephone" class="form-control form-control-sm" placeholder="Téléphone" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label fw-bold small text-warning">Origine Poulet</label>
                    <input type="text" @bind="restoEnEdition.OriginePoulet" class="form-control form-control-sm" placeholder="Origine Poulet" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label fw-bold small text-warning">Origine Viande</label>
                    <input type="text" @bind="restoEnEdition.OrigineViande" class="form-control form-control-sm" placeholder="Origine Viande" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label fw-bold small text-warning">Type</label>
                    <select @bind="restoEnEdition.Type" class="form-select form-select-sm">
                        <option value="@TypeRestaurant.Physique">Boutique Physique</option>
                        <option value="@TypeRestaurant.EnLigne">Commande En Ligne Only</option>
                    </select>
                </div>
            </div>
            <div class="row g-3 mb-2">
                <div class="col-12 col-md-2">
                    <label class="form-label fw-bold small text-warning">Type Restaurant</label>
                    <input type="text" @bind="restoEnEdition.RestaurantType" class="form-control form-control-sm" placeholder="Type Restaurant" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label fw-bold small text-warning">Ville</label>
                    <input type="text" @bind="restoEnEdition.Ville" class="form-control form-control-sm" placeholder="Ville" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label fw-bold small text-warning">Type Nourriture</label>
                    <input type="text" @bind="restoEnEdition.Food" class="form-control form-control-sm" placeholder="Type Nourriture" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label fw-bold small text-warning">Note</label>
                    <select @bind="restoEnEdition.Rating" class="form-select form-select-sm">
                        <option value="">Note (étoiles)</option>
                        <option value="1">★ 1</option>
                        <option value="2">★★ 2</option>
                        <option value="3">★★★ 3</option>
                        <option value="4">★★★★ 4</option>
                        <option value="5">★★★★★ 5</option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label fw-bold small text-warning">Prix</label>
                    <select @bind="restoEnEdition.PriceLevel" class="form-select form-select-sm">
                        <option value="">Prix</option>
                        <option value="1">$</option>
                        <option value="2">$$</option>
                        <option value="3">$$$</option>
                    </select>
                </div>
            </div>
            <div class="row g-3">
                @if (restoEnEdition.Type == TypeRestaurant.Physique)
                {
                    <div class="col-md-8">
                        <label class="form-label fw-bold small text-warning">Lien Google Maps</label>
                    </div>
                }
                else
                {
                    <div class="col-md-8">
                        <label class="form-label fw-bold small text-warning">Lien du site de commande</label>
                    </div>
                }
                <div class="col-md-2">
                    <label class="form-label fw-bold small text-warning">Fiable</label>
                </div>
            </div>
            <div class="row g-3">
                @if (restoEnEdition.Type == TypeRestaurant.Physique)
                {
                    <div class="col-md-8">
                        <input type="text" @bind="restoEnEdition.LienCommande" class="form-control form-control-sm" placeholder="Lien Google Maps" />
                    </div>
                }
                else
                {
                    <div class="col-md-8">
                        <input type="text" @bind="restoEnEdition.LienCommande" class="form-control form-control-sm" placeholder="Lien du site de commande" />
                    </div>
                }
                <div class="col-md-2 d-flex align-items-center">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="restoEnEdition.EstFiable" id="fiableCheckEdit">
                        <label class="form-check-label small" for="fiableCheckEdit">Fiable ✅</label>
                    </div>
                </div>
                <div class="col-12 text-end">
                    <button class="btn btn-warning btn-sm px-4 me-2" @onclick="EnregistrerModifications">Enregistrer les modifications</button>
                    <button class="btn btn-secondary btn-sm px-4" @onclick="AnnulerEdition">Annuler</button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(messageErreur)) { <div class="text-danger small mt-2">@messageErreur</div> }
        </div>
    }

    <div class="card p-3 mb-5 border-secondary shadow-sm">
        <h5 class="card-title text-secondary"><i class="bi bi-funnel"></i> Filtrer les restaurants</h5>
        <div class="row g-2 mb-3">
            <div class="col-12 col-md-2">
                <input type="text" @bind="searchText" class="form-control form-control-sm" placeholder="Recherche texte..." />
            </div>

            <div class="col-12 col-md-1">
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle w-100" type="button" id="ddType" data-bs-toggle="dropdown" aria-expanded="false">Type</button>
                    <ul class="dropdown-menu p-2" aria-labelledby="ddType">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="typePhysique" @onchange="e => ToggleTypeSelection(TypeRestaurant.Physique, ((ChangeEventArgs)e).Value)" checked="@SelectedTypes.Contains(TypeRestaurant.Physique)" />
                            <label class="form-check-label small" for="typePhysique">Physique</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="typeEnLigne" @onchange="e => ToggleTypeSelection(TypeRestaurant.EnLigne, ((ChangeEventArgs)e).Value)" checked="@SelectedTypes.Contains(TypeRestaurant.EnLigne)" />
                            <label class="form-check-label small" for="typeEnLigne">En ligne</label>
                        </div>
                    </ul>
                </div>
            </div>

            <div class="col-12 col-md-2">
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle w-100" type="button" id="ddRestaurantType" data-bs-toggle="dropdown" aria-expanded="false">Type resto</button>
                    <div class="dropdown-menu p-2" aria-labelledby="ddRestaurantType" style="max-height:200px; overflow:auto; min-width:220px">
                        @foreach (var type in RestaurantTypeOptions)
                        {
                            var id = $"rt_{type.Replace(' ', '_')}";
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="@id" @onchange="e => ToggleRestaurantType(type, ((ChangeEventArgs)e).Value)" checked="@SelectedRestaurantTypes.Contains(type)" />
                                <label class="form-check-label small" for="@id">@type</label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-1">
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle w-100" type="button" id="ddVille" data-bs-toggle="dropdown" aria-expanded="false">Ville</button>
                    <div class="dropdown-menu p-2" aria-labelledby="ddVille" style="max-height:200px; overflow:auto; min-width:220px">
                        @foreach (var ville in VilleOptions)
                        {
                            var idv = $"v_{ville.Replace(' ', '_')}";
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="@idv" @onchange="e => ToggleVille(ville, ((ChangeEventArgs)e).Value)" checked="@SelectedVilles.Contains(ville)" />
                                <label class="form-check-label small" for="@idv">@ville</label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-2">
                <div class="d-flex gap-1">
                    <div class="dropdown flex-grow-1">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle w-100" type="button" id="ddRating" data-bs-toggle="dropdown" aria-expanded="false">Note</button>
                        <ul class="dropdown-menu p-2" aria-labelledby="ddRating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var idr = $"r_{i}";
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="@idr" @onchange="e => ToggleRating(i, ((ChangeEventArgs)e).Value)" checked="@SelectedRatings.Contains(i)" />
                                    <label class="form-check-label small" for="@idr">@RenderStars(i)</label>
                                </div>
                            }
                        </ul>
                    </div>

                    <div class="dropdown flex-grow-1">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle w-100" type="button" id="ddPrice" data-bs-toggle="dropdown" aria-expanded="false">Prix</button>
                        <ul class="dropdown-menu p-2" aria-labelledby="ddPrice">
                            @for (int p = 1; p <= 3; p++)
                            {
                                var idp = $"p_{p}";
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="@idp" @onchange="e => TogglePrice(p, ((ChangeEventArgs)e).Value)" checked="@SelectedPrices.Contains(p)" />
                                    <label class="form-check-label small" for="@idp">@RenderPriceLevel(p)</label>
                                </div>
                            }
                        </ul>
                    </div>

                    <div class="dropdown flex-grow-1">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle w-100" type="button" id="ddFiable" data-bs-toggle="dropdown" aria-expanded="false">Fiable</button>
                        <ul class="dropdown-menu p-2" aria-labelledby="ddFiable">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="fiableTrue" @onchange="e => { FilterShowFiable = (bool)(e.Value ?? false); ToggleFiableState(); }" checked="@FilterShowFiable" />
                                <label class="form-check-label small" for="fiableTrue">✅ Fiable</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="fiableFalse" @onchange="e => { FilterShowNonFiable = (bool)(e.Value ?? false); ToggleFiableState(); }" checked="@FilterShowNonFiable" />
                                <label class="form-check-label small" for="fiableFalse">❌ Non fiable</label>
                            </div>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="row g-2">
                    <div class="col-6 col-md-2">
                        <button class="btn btn-outline-primary btn-sm w-100" @onclick="ApplyFilter">Appliquer</button>
                    </div>
                    <div class="col-6 col-md-2">
                        <button class="btn btn-outline-secondary btn-sm w-100" @onclick="ResetFilter">Réinitialiser</button>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="border-top pt-3 mt-3">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span class="fw-bold text-info"><i class="bi bi-sort"></i> Tri:</span>
                        <div class="btn-group btn-group-sm" role="group">
                            <input type="radio" class="btn-check" name="sortOption" id="sortRating" value="rating" @onchange="e => HandleSortChange(e)" checked="@(sortBy == "rating")" />
                            <label class="btn btn-outline-info" for="sortRating">⭐ Note</label>

                            <input type="radio" class="btn-check" name="sortOption" id="sortPrice" value="price" @onchange="e => HandleSortChange(e)" checked="@(sortBy == "price")" />
                            <label class="btn btn-outline-info" for="sortPrice">💰 Prix</label>

                            <input type="radio" class="btn-check" name="sortOption" id="sortDate" value="date" @onchange="e => HandleSortChange(e)" checked="@(sortBy == "date")" />
                            <label class="btn btn-outline-info" for="sortDate">📅 Ajout</label>
                        </div>
                        <button class="btn btn-outline-info btn-sm ms-auto" @onclick="() => { sortAscending = !sortAscending; ApplyFilter(); }" title="@(sortAscending ? "Ordre croissant" : "Ordre décroissant")">
                            @if (sortAscending)
                            {
                                <span aria-hidden="true">↑</span>
                            }
                            else
                            {
                                <span aria-hidden="true">↓</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 border-end">
            <h3 class="mb-3 text-secondary"><i class="bi bi-shop"></i> Établissements Physiques</h3>
            <div class="row row-cols-1 g-3">
                @foreach (var resto in FilteredRestaurants.Where(r => r.Type == TypeRestaurant.Physique))
                {
                    <div class="col">
                        <div class="card shadow-sm border-0 bg-light">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="fw-bold mb-1">@resto.Nom</h5>
                                    <span class="badge @(resto.EstFiable ? "bg-success" : "bg-danger")">
                                        @(resto.EstFiable ? "Fiable" : "Non Fiable")
                                    </span>
                                </div>
                                <div class="d-flex gap-2 align-items-center mb-2">
                                    @if (resto.Rating.HasValue)
                                    {
                                        <span class="small text-warning">@RenderStars(resto.Rating.Value)</span>
                                    }
                                    @if (resto.PriceLevel.HasValue)
                                    {
                                        <span class="small text-success">@RenderPriceLevel(resto.PriceLevel.Value)</span>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(resto.OriginePoulet) || !string.IsNullOrWhiteSpace(resto.OrigineViande))
                                {
                                    <p class="small mb-1">
                                        @if (!string.IsNullOrWhiteSpace(resto.OriginePoulet))
                                        {
                                            <span class="me-3">🍗 @resto.OriginePoulet</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(resto.OriginePoulet) && !string.IsNullOrWhiteSpace(resto.OrigineViande))
                                        {
                                            @* separator removed *@
                                        }
                                        @if (!string.IsNullOrWhiteSpace(resto.OrigineViande))
                                        {
                                            <span>🥩 @resto.OrigineViande</span>
                                        }
                                    </p>
                                }
                                @if (!string.IsNullOrWhiteSpace(resto.Ville) || !string.IsNullOrWhiteSpace(resto.RestaurantType))
                                {
                                    <p class="small mb-1">
                                        @if (!string.IsNullOrWhiteSpace(resto.Ville))
                                        {
                                            <span class="me-3">📍 <strong>@resto.Ville</strong></span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(resto.Ville) && !string.IsNullOrWhiteSpace(resto.RestaurantType))
                                        {
                                            @* separator removed *@
                                        }
                                        @if (!string.IsNullOrWhiteSpace(resto.RestaurantType))
                                        {
                                            <span>🏷️ @resto.RestaurantType</span>
                                        }
                                    </p>
                                }
                                @if (!string.IsNullOrWhiteSpace(resto.Food))
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <p class="small mb-0 text-truncate me-2" style="min-width:0;">🍽️ @resto.Food</p>
                                        @if (!string.IsNullOrWhiteSpace(resto.LienCommande))
                                        {
                                            <a href="@resto.LienCommande" target="_blank" rel="noopener noreferrer" class="resto-icon rounded-circle border border-2 border-primary shadow-sm bg-white" title="Ouvrir sur Google Maps">
                                                <img src="images/googlemapslogo.png" alt="Google Maps" />
                                            </a>
                                        }
                                    </div>
                                }
                                else if (!string.IsNullOrWhiteSpace(resto.LienCommande))
                                {
                                    <div class="d-flex justify-content-end mb-2">
                                        <a href="@resto.LienCommande" target="_blank" rel="noopener noreferrer" class="resto-icon rounded-circle border border-2 border-primary shadow-sm bg-white" title="Ouvrir sur Google Maps">
                                            <img src="images/googlemapslogo.png" alt="Google Maps" />
                                        </a>
                                    </div>
                                }
                                else if (!string.IsNullOrWhiteSpace(resto.Telephone))
                                {
                                    <p class="small mb-1">📞 <a href="tel:@resto.Telephone" class="text-decoration-none">@resto.Telephone</a></p>
                                }
                                <!-- Section Commentaires -->
                                <div class="border-top pt-3 mt-3">
                                    @{
                                        var commentCount = GetComments(resto.Nom).Count;
                                        var badgeClass = commentCount > 0 ? "bg-warning" : "bg-secondary";
                                    }
                                    <button type="button" class="btn btn-sm w-100 mb-2 @(AreCommentsExpanded(resto.Nom) ? "btn-warning" : "btn-outline-secondary")" @onclick="async () => await ChargerCommentaires(resto.Nom)" aria-label="Afficher les commentaires">
                                        <i class="bi bi-chat-left-text"></i>
                                        <span>Afficher les commentaires</span>
                                        <span class="badge @badgeClass ms-2">@commentCount</span>
                                    </button>

                                    @if (AreCommentsExpanded(resto.Nom) && AreCommentsLoaded(resto.Nom))
                                    {
                                        var comments = GetComments(resto.Nom);
                                        
                                        <div class="comments-list mb-3" style="max-height: 250px; overflow-y: auto; border: 1px solid #dee2e6; padding: 10px; border-radius: 5px; background-color: #f8f9fa;">
                                            @if (comments.Count == 0)
                                            {
                                                <p class="text-muted small mb-0">Aucun commentaire pour le moment.</p>
                                            }
                                            else
                                            {
                                                @foreach (var comment in comments)
                                                {
                                                    <div class="comment-item mb-2 pb-2 border-bottom">
                                                        @if (editingCommentId == comment.Id)
                                                        {
                                                            <div>
                                                                <textarea class="form-control form-control-sm" rows="2" @bind="editingCommentText"></textarea>
                                                                <div class="mt-2 d-flex gap-2">
