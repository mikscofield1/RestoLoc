    private async Task ApplyFilterAsync()
    {
        await RunWithLoading("Filtrage et tri des restaurants en cours…", async () =>
        {
            var text = searchText?.Trim().ToLowerInvariant() ?? string.Empty;
            var filtered = ListeRestaurants.Where(r =>
            {
                // Chercher dans les propriétés du restaurant
                var matchRestaurant = string.IsNullOrEmpty(text) ||
                    (r.Nom?.Contains(text, StringComparison.OrdinalIgnoreCase) == true) ||
                    (r.Telephone?.Contains(text, StringComparison.OrdinalIgnoreCase) == true) ||
                    (r.OriginePoulet?.Contains(text, StringComparison.OrdinalIgnoreCase) == true) ||
                    (r.OrigineViande?.Contains(text, StringComparison.OrdinalIgnoreCase) == true) ||
                    (r.RestaurantType?.Contains(text, StringComparison.OrdinalIgnoreCase) == true) ||
                    (r.Food?.Contains(text, StringComparison.OrdinalIgnoreCase) == true) ||
                    (r.LienCommande?.Contains(text, StringComparison.OrdinalIgnoreCase) == true);

                // Chercher dans les commentaires
                var matchComments = false;
                if (!string.IsNullOrEmpty(text) && !string.IsNullOrEmpty(r.Nom) && commentsCache.ContainsKey(r.Nom))
                {
                    matchComments = commentsCache[r.Nom].Any(c => 
                        c.Texte?.Contains(text, StringComparison.OrdinalIgnoreCase) == true);
                }

                return (matchRestaurant || matchComments) &&
                    (SelectedTypes.Count == 0 || SelectedTypes.Contains(r.Type)) &&
                    (SelectedRestaurantTypes.Count == 0 || SelectedRestaurantTypes.Contains(r.RestaurantType ?? string.Empty)) &&
                    (SelectedVilles.Count == 0 || SelectedVilles.Contains(r.Ville ?? string.Empty)) &&
                    (SelectedRatings.Count == 0 || (r.Rating.HasValue && SelectedRatings.Contains(r.Rating.Value))) &&
                    (SelectedPrices.Count == 0 || (r.PriceLevel.HasValue && SelectedPrices.Contains(r.PriceLevel.Value))) &&
                    ((FilterShowFiable || FilterShowNonFiable) && 
                        ((FilterShowFiable && r.EstFiable) || (FilterShowNonFiable && !r.EstFiable)));
            }).ToList();

            // Appliquer le tri - séparer restaurants avec valeur de ceux sans valeur
            FilteredRestaurants = sortBy switch
            {
                "rating" => sortAscending 
                    ? filtered.OrderBy(r => !r.Rating.HasValue).ThenBy(r => r.Rating).ToList()
                    : filtered.OrderBy(r => !r.Rating.HasValue).ThenByDescending(r => r.Rating).ToList(),
                "price" => sortAscending 
                    ? filtered.OrderBy(r => !r.PriceLevel.HasValue).ThenBy(r => r.PriceLevel).ToList()
                    : filtered.OrderBy(r => !r.PriceLevel.HasValue).ThenByDescending(r => r.PriceLevel).ToList(),
                "created_at" => sortAscending 
                    ? filtered.OrderBy(r => !r.CreatedAt.HasValue).ThenBy(r => r.CreatedAt).ToList()
                    : filtered.OrderBy(r => !r.CreatedAt.HasValue).ThenByDescending(r => r.CreatedAt).ToList(),
                _ => filtered
            };
            
            await Task.CompletedTask;
        });
    }

