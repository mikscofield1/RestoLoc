@page "/"
@inject IJSRuntime JS
@inject HttpClient Http
@inject SupabaseService SupabaseService
@using RestoLoc.Services

<PageTitle>RestoLoc Pro</PageTitle>

<div class="container mt-4">
    <section class="hero-card food-hero mb-5 p-5 shadow-soft">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start gap-4">
            <div>
                <h1 class="hero-title mb-3">Mahalal: le halal mahali</h1>
            </div>
            <div class="text-lg-end align-self-center">
                <span class="badge bg-gradient py-2 px-3">Food App</span>
            </div>
        </div>
    </section>

    <!-- Section Ajouter/Éditer -->
    @if (restoEnEdition == null)
    {
        <div class="card mb-5 border-primary shadow-sm">
            <div class="card-header p-3 bg-light">
                <button class="btn btn-link btn-sm text-primary text-decoration-none" @onclick="@(() => showAddForm = !showAddForm)" data-bs-toggle="collapse" data-bs-target="#addRestaurantForm">
                    <i class="bi @(showAddForm ? "bi-dash-lg" : "bi-plus-lg")"></i> 
                    <span class="fw-bold">Ajouter un restaurant</span>
                </button>
            </div>
            <div id="addRestaurantForm" class="collapse @(showAddForm ? "show" : "")" style="@(showAddForm ? "" : "")">
                <div class="card-body p-3">
                    <p class="small text-muted mb-3">Seul le nom est obligatoire. Les autres champs sont optionnels.</p>
                    <div class="row g-3">
                <div class="col-md-3">
                    <input type="text" @bind="nouveauResto.Nom" class="form-control form-control-sm" placeholder="Nom du restaurant" />
                </div>
                <div class="col-md-3">
                    <input type="text" @bind="nouveauResto.Telephone" class="form-control form-control-sm" placeholder="Téléphone" />
                </div>
                <div class="col-md-2">
                    <input type="text" @bind="nouveauResto.OriginePoulet" class="form-control form-control-sm" placeholder="Origine Poulet" />
                </div>
                <div class="col-md-2">
                    <input type="text" @bind="nouveauResto.OrigineViande" class="form-control form-control-sm" placeholder="Origine Viande" />
                </div>
                <div class="col-md-2">
                    <select @bind="nouveauResto.Type" class="form-select form-select-sm">
                        <option value="@TypeRestaurant.Physique">Boutique Physique</option>
                        <option value="@TypeRestaurant.EnLigne">Commande En Ligne Only</option>
                    </select>
                </div>
                <div class="col-12"></div>
                <div class="col-md-3">
                    <input type="text" @bind="nouveauResto.RestaurantType" class="form-control form-control-sm" placeholder="Type Restaurant" />
                </div>
                <div class="col-md-3">
                    <input type="text" @bind="nouveauResto.Ville" class="form-control form-control-sm" placeholder="Ville" />
                </div>
                <div class="col-md-3">
                    <input type="text" @bind="nouveauResto.Food" class="form-control form-control-sm" placeholder="Type Nourriture" />
                </div>
                <div class="col-md-3"></div>
                <div class="col-12"></div>
            </div>
            <div class="row g-3">
                @if (nouveauResto.Type == TypeRestaurant.Physique)
                {
                    <div class="col-md-6">
                        <input type="text" @bind="urlGoogleMaps" class="form-control form-control-sm" placeholder="Lien Google Maps (Optionnel)" />
                    </div>
                    <div class="col-md-4"></div>
                }
                else
                {
                    <div class="col-md-6">
                        <input type="text" @bind="nouveauResto.LienCommande" class="form-control form-control-sm" placeholder="Lien du site de commande (Optionnel)" />
                    </div>
                    <div class="col-md-4"></div>
                }
                <div class="col-md-2 d-flex align-items-center">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="nouveauResto.EstFiable" id="fiableCheck">
                        <label class="form-check-label small" for="fiableCheck">Fiable ✅</label>
                    </div>
                </div>
                <div class="col-12 text-end">
                    <button class="btn btn-success btn-sm px-4" @onclick="AjouterLeRestaurant">Enregistrer</button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(messageErreur)) { <div class="text-danger small mt-2">@messageErreur</div> }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card p-3 mb-5 border-warning shadow-sm">
            <h5 class="card-title text-warning"><i class="bi bi-pencil-fill"></i> Éditer le restaurant</h5>
            <div class="row g-3 mb-2">
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-warning">Nom du restaurant</label>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold small text-warning">Téléphone</label>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold small text-warning">Origine Poulet</label>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold small text-warning">Origine Viande</label>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-warning">Type</label>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-md-3">
                    <input type="text" @bind="restoEnEdition.Nom" class="form-control form-control-sm" placeholder="Nom du restaurant" />
                </div>
                <div class="col-md-2">
                    <input type="text" @bind="restoEnEdition.Telephone" class="form-control form-control-sm" placeholder="Téléphone" />
                </div>
                <div class="col-md-2">
                    <input type="text" @bind="restoEnEdition.OriginePoulet" class="form-control form-control-sm" placeholder="Origine Poulet" />
                </div>
                <div class="col-md-2">
                    <input type="text" @bind="restoEnEdition.OrigineViande" class="form-control form-control-sm" placeholder="Origine Viande" />
                </div>
                <div class="col-md-3">
                    <select @bind="restoEnEdition.Type" class="form-select form-select-sm">
                        <option value="@TypeRestaurant.Physique">Boutique Physique</option>
                        <option value="@TypeRestaurant.EnLigne">Commande En Ligne Only</option>
                    </select>
                </div>
                <div class="col-12"></div>
                <div class="col-md-2">
                    <label class="form-label fw-bold small text-warning">Type Restaurant</label>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold small text-warning">Ville</label>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold small text-warning">Type Nourriture</label>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-md-2">
                    <input type="text" @bind="restoEnEdition.RestaurantType" class="form-control form-control-sm" placeholder="Type Restaurant" />
                </div>
                <div class="col-md-2">
                    <input type="text" @bind="restoEnEdition.Ville" class="form-control form-control-sm" placeholder="Ville" />
                </div>
                <div class="col-md-2">
                    <input type="text" @bind="restoEnEdition.Food" class="form-control form-control-sm" placeholder="Type Nourriture" />
                </div>
                <div class="col-12"></div>
                @if (restoEnEdition.Type == TypeRestaurant.Physique)
                {
                    <div class="col-md-8">
                        <label class="form-label fw-bold small text-warning">Lien Google Maps</label>
                    </div>
                }
                else
                {
                    <div class="col-md-8">
                        <label class="form-label fw-bold small text-warning">Lien du site de commande</label>
                    </div>
                }
                <div class="col-md-2">
                    <label class="form-label fw-bold small text-warning">Fiable</label>
                </div>
            </div>
            <div class="row g-3">
                @if (restoEnEdition.Type == TypeRestaurant.Physique)
                {
                    <div class="col-md-8">
                        <input type="text" @bind="restoEnEdition.LienCommande" class="form-control form-control-sm" placeholder="Lien Google Maps" />
                    </div>
                }
                else
                {
                    <div class="col-md-8">
                        <input type="text" @bind="restoEnEdition.LienCommande" class="form-control form-control-sm" placeholder="Lien du site de commande" />
                    </div>
                }
                <div class="col-md-2 d-flex align-items-center">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="restoEnEdition.EstFiable" id="fiableCheckEdit">
                        <label class="form-check-label small" for="fiableCheckEdit">Fiable ✅</label>
                    </div>
                </div>
                <div class="col-12 text-end">
                    <button class="btn btn-warning btn-sm px-4 me-2" @onclick="EnregistrerModifications">Enregistrer les modifications</button>
                    <button class="btn btn-secondary btn-sm px-4" @onclick="AnnulerEdition">Annuler</button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(messageErreur)) { <div class="text-danger small mt-2">@messageErreur</div> }
        </div>
    }

    <div class="card p-3 mb-5 border-secondary shadow-sm">
        <h5 class="card-title text-secondary"><i class="bi bi-funnel"></i> Filtrer les restaurants</h5>
        <div class="row g-3 mb-3">
            <div class="col-12 col-md-3">
                <input type="text" @bind="searchText" class="form-control form-control-sm" placeholder="Recherche texte..." />
            </div>
            <div class="col-12 col-md-2">
                <select @bind="searchType" class="form-select form-select-sm">
                    <option value="">Tous types</option>
                    <option value="Physique">Physique</option>
                    <option value="EnLigne">En ligne</option>
                </select>
            </div>
            <div class="col-12 col-md-3">
                <select @bind="searchRestaurantType" class="form-select form-select-sm">
                    <option value="">Tous types restaurant</option>
                    @foreach (var type in RestaurantTypeOptions)
                    {
                        <option value="@type">@type</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-2">
                <select @bind="searchVille" class="form-select form-select-sm">
                    <option value="">Toutes villes</option>
                    @foreach (var ville in VilleOptions)
                    {
                        <option value="@ville">@ville</option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-1 d-grid">
                <button class="btn btn-outline-primary btn-sm" @onclick="ApplyFilter">Appliquer</button>
            </div>
            <div class="col-6 col-md-1 d-grid">
                <button class="btn btn-outline-secondary btn-sm" @onclick="ResetFilter">Réinitialiser</button>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 border-end">
            <h3 class="mb-3 text-secondary"><i class="bi bi-shop"></i> Établissements Physiques</h3>
            <div class="row row-cols-1 g-3">
                @foreach (var resto in FilteredRestaurants.Where(r => r.Type == TypeRestaurant.Physique))
                {
                    <div class="col">
                        <div class="card shadow-sm border-0 bg-light">
                            <div class="card-body">
                                <div class="d-flex justify-content-between mb-2">
                                    <h5 class="fw-bold">@resto.Nom</h5>
                                    <span class="badge @(resto.EstFiable ? "bg-success" : "bg-danger")">
                                        @(resto.EstFiable ? "Fiable" : "Non Fiable")
                                    </span>
                                </div>
                                          <p class="small mb-1">🍗 Poulet : @resto.OriginePoulet | 🥩 Viande : @resto.OrigineViande</p>
                                        <p class="small mb-1">📍 <strong>@resto.Ville</strong> | 🏢 Type : @resto.RestaurantType</p>
                                        @if (!string.IsNullOrWhiteSpace(resto.Food))
                                        {
                                            <p class="small mb-1">🍽️ Nourriture : @resto.Food</p>
                                        }
                                          <p class="small mb-2">📞 Tél : <a href="tel:@resto.Telephone">@resto.Telephone</a></p>
                                @if (!string.IsNullOrWhiteSpace(resto.LienCommande))
                                {
                                    <a href="@resto.LienCommande" target="_blank" class="btn btn-outline-primary btn-sm w-100 mb-2">
                                        <i class="bi bi-geo-alt-fill"></i> Ouvrir sur Google Maps
                                    </a>
                                }
                                
                                <!-- Section Commentaires -->
                                <div class="border-top pt-3 mt-3">
                                    @{
                                        var commentCount = GetComments(resto.Nom).Count;
                                        var badgeClass = commentCount > 0 ? "bg-warning" : "bg-secondary";
                                    }
                                    <button type="button" class="btn btn-sm w-100 mb-2 @(AreCommentsExpanded(resto.Nom) ? "btn-warning" : "btn-outline-secondary")" @onclick="async () => await ChargerCommentaires(resto.Nom)">
                                        <i class="bi @(AreCommentsExpanded(resto.Nom) ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                        <span>@(AreCommentsExpanded(resto.Nom) ? "Masquer" : "Voir") les commentaires</span>
                                        <span class="badge @badgeClass ms-2">@commentCount</span>
                                    </button>

                                    @if (AreCommentsExpanded(resto.Nom) && AreCommentsLoaded(resto.Nom))
                                    {
                                        var comments = GetComments(resto.Nom);
                                        
                                        <div class="comments-list mb-3" style="max-height: 250px; overflow-y: auto; border: 1px solid #dee2e6; padding: 10px; border-radius: 5px; background-color: #f8f9fa;">
                                            @if (comments.Count == 0)
                                            {
                                                <p class="text-muted small mb-0">Aucun commentaire pour le moment.</p>
                                            }
                                            else
                                            {
                                                @foreach (var comment in comments)
                                                {
                                                    <div class="comment-item mb-2 pb-2 border-bottom">
                                                        @if (editingCommentId == comment.Id)
                                                        {
                                                            <div>
                                                                <textarea class="form-control form-control-sm" rows="2" @bind="editingCommentText"></textarea>
                                                                <div class="mt-2 d-flex gap-2">
                                                                    <button type="button" class="btn btn-success btn-sm flex-grow-1" @onclick="async () => await EnregistrerEditionCommentaire(resto.Nom, comment)">
                                                                        <i class="bi bi-check-lg"></i> Enregistrer
                                                                    </button>
                                                                    <button type="button" class="btn btn-secondary btn-sm" @onclick="AnnulerEditionCommentaire">
                                                                        <i class="bi bi-x-lg"></i> Annuler
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="d-flex justify-content-between align-items-start">
                                                                <div class="flex-grow-1">
                                                                    <p class="mb-1 small" style="white-space: pre-wrap; word-wrap: break-word;">@comment.Texte</p>
                                                                    <small class="text-muted">@comment.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                                                </div>
                                                                <div class="d-flex gap-1">
                                                                    <button type="button" class="btn btn-sm btn-outline-warning" @onclick="() => CommencerEditionCommentaire(comment)" title="Éditer">
                                                                        <i class="bi bi-pencil"></i>
                                                                    </button>
                                                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="async () => await SupprimerCommentaire(resto.Nom, comment)" title="Supprimer">
                                                                        <i class="bi bi-trash"></i>
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            }
                                        </div>

                                        <!-- Formulaire d'ajout de commentaire -->
                                        <button type="button" class="btn btn-success btn-sm w-100 mb-2" @onclick="() => ToggleCommentForm(resto.Nom)">
                                            <i class="bi bi-plus-lg"></i> Ajouter un commentaire
                                        </button>

                                        @if (IsCommentFormVisible(resto.Nom))
                                        {
                                            <div class="card card-body p-2 mb-2" style="background-color: #f0f8ff;">
                                                <textarea class="form-control form-control-sm" rows="3" placeholder="Entrez votre commentaire (ex: Pizza tikka bonne, Limonade trop sucrée, Arancini chers...)" value="@GetNewCommentText(resto.Nom)" @oninput="@(e => SetNewCommentText(resto.Nom, e.Value?.ToString() ?? ""))"></textarea>
                                                <div class="mt-2 d-flex gap-2">
                                                    <button type="button" class="btn btn-success btn-sm flex-grow-1" @onclick="async () => await AjouterCommentaire(resto.Nom)">
                                                        <i class="bi bi-check-lg"></i> Envoyer
                                                    </button>
                                                    <button type="button" class="btn btn-secondary btn-sm" @onclick="() => ToggleCommentForm(resto.Nom)">
                                                        <i class="bi bi-x-lg"></i> Annuler
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>

                                <div class="btn-group w-100" role="group">
                                    <button type="button" class="btn btn-outline-warning btn-sm" @onclick="() => CommencerEdition(resto)">
                                        <i class="bi bi-pencil"></i> Éditer
                                    </button>
                                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="async () => await SupprimerRestaurant(resto)">
                                        <i class="bi bi-trash"></i> Supprimer
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string searchText = string.Empty;
    private string searchType = string.Empty;
    private string searchRestaurantType = string.Empty;
    private string searchVille = string.Empty;
    private List<string> RestaurantTypeOptions = new();
    private List<string> VilleOptions = new();
    private string urlGoogleMaps = string.Empty;
    private string messageErreur = string.Empty;
    private Restaurant nouveauResto = new();
    private Restaurant? restoEnEdition = null;
    private List<Restaurant> ListeRestaurants = new();
    private List<Restaurant> FilteredRestaurants = new();
    private bool showAddForm = false;

    // Variables pour les commentaires
    private Dictionary<string, List<Comment>> commentsCache = new();
    private Dictionary<string, bool> expandedComments = new();
    private Dictionary<string, string> newCommentText = new();
    private Dictionary<string, bool> showCommentForm = new();
    
    // Variables pour l'édition des commentaires
    private int? editingCommentId = null;
    private string editingCommentText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await ChargerRestaurants();
    }

    private async Task ChargerRestaurants()
    {
        try
        {
            ListeRestaurants = await SupabaseService.GetRestaurantsAsync();
            RestaurantTypeOptions = ListeRestaurants
                .Select(r => r.RestaurantType)
                .Where(value => !string.IsNullOrWhiteSpace(value))
                .Distinct()
                .OrderBy(value => value)
                .ToList();

            VilleOptions = ListeRestaurants
                .Select(r => r.Ville)
                .Where(value => !string.IsNullOrWhiteSpace(value))
                .Distinct()
                .OrderBy(value => value)
                .ToList();

            FilteredRestaurants = ListeRestaurants.ToList();

            // Pré-charger les commentaires pour tous les restaurants
            foreach (var resto in ListeRestaurants)
            {
                var comments = await SupabaseService.GetCommentsByRestaurantAsync(resto.Nom);
                commentsCache[resto.Nom] = comments;
            }
        }
        catch (Exception ex)
        {
            messageErreur = $"Erreur lors du chargement des restaurants: {ex.Message}";
        }
    }

    private void ApplyFilter()
    {
        var text = searchText?.Trim().ToLowerInvariant() ?? string.Empty;

        FilteredRestaurants = ListeRestaurants.Where(r =>
            (string.IsNullOrEmpty(text) ||
                (r.Nom?.Contains(text, StringComparison.OrdinalIgnoreCase) == true) ||
                (r.Telephone?.Contains(text, StringComparison.OrdinalIgnoreCase) == true) ||
                (r.OriginePoulet?.Contains(text, StringComparison.OrdinalIgnoreCase) == true) ||
                (r.OrigineViande?.Contains(text, StringComparison.OrdinalIgnoreCase) == true) ||
                (r.RestaurantType?.Contains(text, StringComparison.OrdinalIgnoreCase) == true) ||
                (r.Food?.Contains(text, StringComparison.OrdinalIgnoreCase) == true) ||
                (r.LienCommande?.Contains(text, StringComparison.OrdinalIgnoreCase) == true)
            ) &&
            (string.IsNullOrEmpty(searchType) || r.Type.ToString() == searchType) &&
            (string.IsNullOrEmpty(searchRestaurantType) || r.RestaurantType == searchRestaurantType) &&
            (string.IsNullOrEmpty(searchVille) || r.Ville == searchVille)
        ).ToList();
    }

    private void ResetFilter()
    {
        searchText = string.Empty;
        searchType = string.Empty;
        searchRestaurantType = string.Empty;
        searchVille = string.Empty;
        FilteredRestaurants = ListeRestaurants.ToList();
    }

    private void CommencerEdition(Restaurant resto)
    {
        // Créer une copie pour l'édition
        restoEnEdition = new Restaurant
        {
            Id = resto.Id,
            Nom = resto.Nom,
            Telephone = resto.Telephone,
            OriginePoulet = resto.OriginePoulet,
            OrigineViande = resto.OrigineViande,
            Type = resto.Type,
            EstFiable = resto.EstFiable,
            LienCommande = resto.LienCommande,
            RestaurantType = resto.RestaurantType,
            Ville = resto.Ville,
            Food = resto.Food
        };
        messageErreur = string.Empty;
    }

    private void AnnulerEdition()
    {
        restoEnEdition = null;
        messageErreur = string.Empty;
    }

    private async Task EnregistrerModifications()
    {
        if (restoEnEdition == null)
            return;

        messageErreur = string.Empty;

        // Validation du nom
        if (string.IsNullOrWhiteSpace(restoEnEdition.Nom))
        {
            messageErreur = "Le nom du restaurant est obligatoire.";
            return;
        }

        try
        {
            var success = await SupabaseService.UpdateRestaurantAsync(restoEnEdition);
            if (success)
            {
                restoEnEdition = null;
                await ChargerRestaurants();
            }
            else
            {
                messageErreur = "Erreur lors de la mise à jour du restaurant.";
            }
        }
        catch (Exception ex)
        {
            messageErreur = $"Erreur: {ex.Message}";
        }
    }

    private async Task SupprimerRestaurant(Restaurant resto)
    {
        try
        {
            var success = await SupabaseService.DeleteRestaurantAsync(resto.Nom);
            if (success)
            {
                await ChargerRestaurants();
            }
            else
            {
                messageErreur = "Erreur lors de la suppression du restaurant.";
            }
        }
        catch (Exception ex)
        {
            messageErreur = $"Erreur: {ex.Message}";
        }
    }

    private async Task AjouterLeRestaurant()
    {
        messageErreur = string.Empty;

        // Si l'utilisateur a collé une URL, on tente l'analyse automatique
        if (!string.IsNullOrWhiteSpace(urlGoogleMaps))
        {
            urlGoogleMaps = await Calculs.ResolveGoogleMapsShortUrlAsync(Http, urlGoogleMaps);
            var restoAutomatique = Calculs.AnalyserUrlGoogleMaps(urlGoogleMaps);
            if (restoAutomatique != null)
            {
                // Si le nom a été trouvé dans l'URL, on le prend, sinon on garde celui du champ texte
                if (!string.IsNullOrEmpty(restoAutomatique.Nom))
                {
                    nouveauResto.Nom = restoAutomatique.Nom;
                }

                nouveauResto.LienCommande = restoAutomatique.LienCommande;
                nouveauResto.Type = TypeRestaurant.Physique;
                nouveauResto.EstFiable = true;
            }
            else
            {
                messageErreur = "Impossible d'analyser cette URL. Vérifiez qu'il s'agit d'un lien complet du navigateur.";
                return;
            }
        }

        // Validation finale du nom
        if (string.IsNullOrWhiteSpace(nouveauResto.Nom))
        {
            messageErreur = "Le nom du restaurant n'a pas pu être détecté et est obligatoire.";
            return;
        }

        try
        {
            var success = await SupabaseService.AddRestaurantAsync(nouveauResto);
            if (success)
            {
                // Réinitialisation
                nouveauResto = new Restaurant();
                urlGoogleMaps = string.Empty;
                await ChargerRestaurants();
            }
            else
            {
                messageErreur = "Erreur lors de l'ajout du restaurant.";
            }
        }
        catch (Exception ex)
        {
            messageErreur = $"Erreur: {ex.Message}";
        }
    }

    // Méthodes pour les commentaires
    private async Task ChargerCommentaires(string restaurantNom)
    {
        if (!commentsCache.ContainsKey(restaurantNom))
        {
            var comments = await SupabaseService.GetCommentsByRestaurantAsync(restaurantNom);
            commentsCache[restaurantNom] = comments;
        }
        
        if (!expandedComments.ContainsKey(restaurantNom))
            expandedComments[restaurantNom] = false;
        
        expandedComments[restaurantNom] = !expandedComments[restaurantNom];
    }

    private async Task AjouterCommentaire(string restaurantNom)
    {
        if (!newCommentText.ContainsKey(restaurantNom) || string.IsNullOrWhiteSpace(newCommentText[restaurantNom]))
            return;

        try
        {
            var comment = new Comment
            {
                RestaurantNom = restaurantNom,
                Texte = newCommentText[restaurantNom],
                CreatedAt = DateTime.Now
            };

            var success = await SupabaseService.AddCommentAsync(comment);
            if (success)
            {
                newCommentText[restaurantNom] = string.Empty;
                showCommentForm[restaurantNom] = false;
                
                // Recharger les commentaires
                commentsCache[restaurantNom] = await SupabaseService.GetCommentsByRestaurantAsync(restaurantNom);
            }
        }
        catch (Exception ex)
        {
            messageErreur = $"Erreur lors de l'ajout du commentaire: {ex.Message}";
        }
    }

    private async Task SupprimerCommentaire(string restaurantNom, Comment comment)
    {
        try
        {
            var success = await SupabaseService.DeleteCommentAsync(comment.Id);
            if (success)
            {
                // Recharger les commentaires
                commentsCache[restaurantNom] = await SupabaseService.GetCommentsByRestaurantAsync(restaurantNom);
            }
        }
        catch (Exception ex)
        {
            messageErreur = $"Erreur lors de la suppression du commentaire: {ex.Message}";
        }
    }

    private bool AreCommentsLoaded(string restaurantNom)
    {
        return commentsCache.ContainsKey(restaurantNom);
    }

    private List<Comment> GetComments(string restaurantNom)
    {
        return commentsCache.ContainsKey(restaurantNom) ? commentsCache[restaurantNom] : new List<Comment>();
    }

    private bool AreCommentsExpanded(string restaurantNom)
    {
        return expandedComments.ContainsKey(restaurantNom) && expandedComments[restaurantNom];
    }

    private string GetNewCommentText(string restaurantNom)
    {
        return newCommentText.ContainsKey(restaurantNom) ? newCommentText[restaurantNom] : string.Empty;
    }

    private void SetNewCommentText(string restaurantNom, string text)
    {
        newCommentText[restaurantNom] = text;
    }

    private bool IsCommentFormVisible(string restaurantNom)
    {
        return showCommentForm.ContainsKey(restaurantNom) && showCommentForm[restaurantNom];
    }

    private void ToggleCommentForm(string restaurantNom)
    {
        if (!showCommentForm.ContainsKey(restaurantNom))
            showCommentForm[restaurantNom] = false;
        
        showCommentForm[restaurantNom] = !showCommentForm[restaurantNom];
    }

    private void CommencerEditionCommentaire(Comment comment)
    {
        editingCommentId = comment.Id;
        editingCommentText = comment.Texte;
    }

    private void AnnulerEditionCommentaire()
    {
        editingCommentId = null;
        editingCommentText = string.Empty;
    }

    private async Task EnregistrerEditionCommentaire(string restaurantNom, Comment comment)
    {
        if (editingCommentId == null || string.IsNullOrWhiteSpace(editingCommentText))
            return;

        try
        {
            var updatedComment = new Comment
            {
                Id = (int)editingCommentId,
                RestaurantNom = restaurantNom,
                Texte = editingCommentText,
                CreatedAt = comment.CreatedAt
            };

            var success = await SupabaseService.UpdateCommentAsync(updatedComment);
            if (success)
            {
                editingCommentId = null;
                editingCommentText = string.Empty;
                
                // Recharger les commentaires
                commentsCache[restaurantNom] = await SupabaseService.GetCommentsByRestaurantAsync(restaurantNom);
            }
        }
        catch (Exception ex)
        {
            messageErreur = $"Erreur lors de la mise à jour du commentaire: {ex.Message}";
        }
    }
}