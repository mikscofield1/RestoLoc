    private async Task AjouterLeRestaurant()
    {
        messageErreur = string.Empty;

        // Si l'utilisateur a collé une URL, on tente l'analyse automatique
        if (!string.IsNullOrWhiteSpace(urlGoogleMaps))
        {
            urlGoogleMaps = await Calculs.ResolveGoogleMapsShortUrlAsync(urlGoogleMaps);
            extractedAnalysis = await Calculs.AnalyserUrlGoogleMapsAsync(urlGoogleMaps);
            if (extractedAnalysis == null)
            {
                messageErreur = "Impossible d'analyser cette URL. Vérifiez qu'il s'agit d'un lien Google Maps valide.";
                return;
            }

            if (extractedAnalysis.NeedsConfirmation)
            {
                // Il y a un doute : demander confirmation à l'utilisateur via la box de validation
                showAnalysisConfirmation = true;
                showCityConfirmationModal = false;
                fieldAccepted = new() { { "nom", false }, { "ville", false } };
            }
            else
            {
                // Aucun doute : appliquer automatiquement les valeurs extraites et ajouter
                var r = extractedAnalysis.Resto;
                if (!string.IsNullOrEmpty(r.Nom)) nouveauResto.Nom = r.Nom;
                if (!string.IsNullOrEmpty(r.Ville)) nouveauResto.Ville = r.Ville;
                if (!string.IsNullOrEmpty(r.LienCommande)) nouveauResto.LienCommande = r.LienCommande;
                nouveauResto.Type = TypeRestaurant.Physique;
                await PerformAddRestaurant(nouveauResto);
            }
            return;
        }

        // Pas d'URL fournie => ajouter manuellement
        // Validation finale du nom
        if (string.IsNullOrWhiteSpace(nouveauResto.Nom))
        {
            messageErreur = "Le nom du restaurant n'a pas pu être détecté et est obligatoire.";
            return;
        }

        nouveauResto.Type = TypeRestaurant.Physique;
        await PerformAddRestaurant(nouveauResto);
    }

    private async Task PerformAddRestaurant(Restaurant restoToAdd)
    {
        try
        {
            if (!restoToAdd.CreatedAt.HasValue)
            {
                restoToAdd.CreatedAt = TruncateToMinute(DateTime.UtcNow);
            }
            else
            {
                restoToAdd.CreatedAt = TruncateToMinute(restoToAdd.CreatedAt.Value);
            }

            await RunWithLoading("Ajout du restaurant en cours…", async () =>
            {
                var success = await SupabaseService.AddRestaurantAsync(restoToAdd);
                if (success)
                {
                    // Réinitialisation
                    nouveauResto = new Restaurant();
                    urlGoogleMaps = string.Empty;
                    extractedAnalysis = null;
                    showAnalysisConfirmation = false;
                    await ChargerRestaurants();
                    // Ferme le panneau d'ajout après succès
                    showAddForm = false;
                    messageErreur = string.Empty;
                    await ShowTemporarySuccessMessage("Restaurant ajouté avec succès.");
                }
                else
                {
                    messageErreur = SupabaseService.LastErrorMessage ?? "Erreur lors de l'ajout du restaurant.";
                }
            });
        }
        catch (Exception ex)
        {
            messageErreur = $"Erreur: {ex.Message}";
        }
    }

    private static DateTime TruncateToMinute(DateTime dateTime)
    {
        var utc = dateTime.Kind == DateTimeKind.Utc ? dateTime : dateTime.ToUniversalTime();
        return new DateTime(utc.Year, utc.Month, utc.Day, utc.Hour, utc.Minute, 0, DateTimeKind.Utc);
    }

    private async Task ShowTemporarySuccessMessage(string message)
    {
        successMessageCts?.Cancel();
        successMessageCts = new CancellationTokenSource();
        messageSuccess = message;

        try
        {
            await Task.Delay(1000, successMessageCts.Token);
            messageSuccess = string.Empty;
        }
        catch (TaskCanceledException)
        {
            // Ignorer si annulé par un nouveau message
        }
        finally
        {
            successMessageCts?.Dispose();
            successMessageCts = null;
        }
    }

    private async Task ConfirmExtractedAndAdd()
    {
        if (extractedAnalysis != null)
        {
            // s'assurer que nouveauResto contient les données extraites
            var r = extractedAnalysis.Resto;
            // Le nom est toujours pris directement
            if (!string.IsNullOrEmpty(r.Nom)) 
                nouveauResto.Nom = r.Nom;
            // La ville est acceptée si confirmée par l'utilisateur
            if (!string.IsNullOrEmpty(r.Ville) && fieldAccepted.GetValueOrDefault("ville", false)) 
                nouveauResto.Ville = r.Ville;
            // Le lien est toujours pris directement sans validation
            if (!string.IsNullOrEmpty(r.LienCommande)) 
                nouveauResto.LienCommande = r.LienCommande;

            nouveauResto.Type = TypeRestaurant.Physique;

            // Réinitialiser les acceptations pour la prochaine extraction
            fieldAccepted = new() { { "ville", false } };

            await PerformAddRestaurant(nouveauResto);
        }
    }

